{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-tracking-system/refs/heads/main/json-schema/scheduling-schedule-shift-input-schema.json",
  "title": "ScheduleShiftInput",
  "description": "Input for creating or updating a schedule shift",
  "type": "object",
  "properties": {
    "workerId": {
      "type": "string",
      "description": "Worker ID to assign to the shift"
    },
    "organizationId": {
      "type": "string",
      "description": "Scheduling organization ID"
    },
    "shiftDate": {
      "type": "string",
      "format": "date",
      "description": "Date of the shift"
    },
    "startTime": {
      "type": "string",
      "format": "time",
      "description": "Shift start time"
    },
    "endTime": {
      "type": "string",
      "format": "time",
      "description": "Shift end time"
    },
    "shiftType": {
      "type": "string",
      "description": "Type of shift",
      "enum": ["Regular", "Overtime", "OnCall", "Split"],
      "default": "Regular"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes"
    }
  },
  "required": ["workerId", "shiftDate", "startTime", "endTime"]
}
