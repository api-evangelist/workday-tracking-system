{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-tracking-system/refs/heads/main/json-schema/absence-management-return-from-leave-input-schema.json",
  "title": "ReturnFromLeaveInput",
  "description": "Input for processing a return from leave",
  "type": "object",
  "properties": {
    "returnDate": {
      "type": "string",
      "format": "date",
      "description": "Actual date of return",
      "example": "2026-06-30"
    },
    "comment": {
      "type": "string",
      "description": "Optional comment on the return"
    }
  },
  "required": ["returnDate"]
}
