{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-tracking-system/refs/heads/main/json-structure/scheduling-worker-scheduling-preferences-structure.json",
  "name": "WorkerSchedulingPreferences",
  "description": "A worker's scheduling preferences",
  "type": "object",
  "properties": {
    "workerId": {
      "type": "string",
      "description": "Workday ID of the worker"
    },
    "preferredStartTime": {
      "type": "time",
      "description": "Preferred shift start time"
    },
    "preferredEndTime": {
      "type": "time",
      "description": "Preferred shift end time"
    },
    "preferredDaysOff": {
      "type": "array",
      "description": "Preferred days off",
      "items": {
        "type": "string",
        "enum": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday"
        ]
      }
    },
    "maxHoursPerWeek": {
      "type": "float",
      "description": "Maximum hours per week"
    },
    "minHoursPerWeek": {
      "type": "float",
      "description": "Minimum hours per week"
    },
    "availability": {
      "type": "object",
      "description": "Worker availability by day of week",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          },
          "startTime": {
            "type": "time"
          },
          "endTime": {
            "type": "time"
          }
        }
      }
    }
  }
}
