{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-tracking-system/refs/heads/main/json-structure/absence-management-time-off-entry-structure.json",
  "name": "TimeOffEntry",
  "description": "An employee time off entry",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique Workday ID of the time off entry"
    },
    "workerId": {
      "type": "string",
      "description": "Workday ID of the worker"
    },
    "timeOffType": {
      "type": "string",
      "description": "Type of time off (e.g., Vacation, Sick, Personal)"
    },
    "startDate": {
      "type": "date",
      "description": "Start date of the time off"
    },
    "endDate": {
      "type": "date",
      "description": "End date of the time off"
    },
    "hours": {
      "type": "float",
      "description": "Total hours of time off"
    },
    "days": {
      "type": "float",
      "description": "Total days of time off"
    },
    "status": {
      "type": "string",
      "description": "Approval status of the time off request",
      "enum": [
        "Draft",
        "Submitted",
        "Approved",
        "Denied",
        "Cancelled"
      ]
    },
    "comment": {
      "type": "string",
      "description": "Worker's note on the request"
    },
    "approverComment": {
      "type": "string",
      "description": "Manager's comment on approval/denial"
    },
    "createdAt": {
      "type": "datetime"
    }
  },
  "required": [
    "workerId",
    "timeOffType",
    "startDate",
    "endDate"
  ]
}
