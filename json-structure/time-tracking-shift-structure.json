{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-tracking-system/refs/heads/main/json-structure/time-tracking-shift-structure.json",
  "name": "Shift",
  "description": "A single shift within a work schedule",
  "type": "object",
  "properties": {
    "dayOfWeek": {
      "type": "string",
      "description": "Day of the week for this shift",
      "enum": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ]
    },
    "startTime": {
      "type": "time",
      "description": "Shift start time (HH:MM:SS)"
    },
    "endTime": {
      "type": "time",
      "description": "Shift end time (HH:MM:SS)"
    },
    "hours": {
      "type": "float",
      "description": "Total hours for this shift"
    }
  }
}
